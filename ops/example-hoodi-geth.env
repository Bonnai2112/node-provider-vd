# Example per-couple config for produce-el-template@hoodi-geth.service.
# Install at /etc/platform/templates/hoodi-geth.env and tighten permissions.

NETWORK=hoodi
EL_CLIENT=geth

# Workdir of the frozen node — where its eth-docker clone lives. The script
# runs `docker compose stop/start execution` from this directory.
FROZEN_NODE_DIR=/var/lib/platform/nodes/<frozen-node-uuid>/eth-docker

# Host path of the frozen node's bind-mounted EL datadir (the directory the
# platform created at provisioning time, sibling of eth-docker/).
EL_DATA_DIR=/var/lib/platform/nodes/<frozen-node-uuid>/data

# Optional: TEMPLATES_DIR defaults to /var/lib/platform/templates.
# Optional: COMPRESS_LEVEL defaults to 3 (zstd default).
