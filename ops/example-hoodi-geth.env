# Example per-couple config for produce-el-template@hoodi-geth.service.
# Install at /etc/platform/templates/hoodi-geth.env and tighten permissions.

NETWORK=hoodi
EL_CLIENT=geth

# Workdir of the frozen node — where its eth-docker clone lives. The script
# runs `docker compose stop/start execution` from this directory.
FROZEN_NODE_DIR=/var/lib/platform/nodes/<frozen-node-uuid>/eth-docker

# Host path of the frozen node's bind-mounted EL datadir (the directory the
# platform created at provisioning time, sibling of eth-docker/).
EL_DATA_DIR=/var/lib/platform/nodes/<frozen-node-uuid>/data

# Optional: TEMPLATES_DIR defaults to /var/lib/platform/templates.
# Optional: COMPRESS_LEVEL defaults to 3 (zstd default).

# Optional: ask the platform to restart the frozen node aggregate after the
# tarball is produced. Without these three vars, the reconciler leaves the
# frozen node stuck in STOPPED because no state-machine branch transitions
# out of STOPPED automatically. Setting all three triggers a single
# POST {PLATFORM_API}/nodes/{FROZEN_NODE_ID}/restart with X-Owner-Id header.
# Caveat: systemd EnvironmentFile treats '#' as a comment only at the start of
# a line. Do NOT add inline comments after a value — they become part of the
# value and break UUID parsing on the platform side (HTTP 400).
#PLATFORM_API=http://localhost:8080/api/v1
#FROZEN_NODE_ID=<frozen-node-uuid>
# Dev default owner: 11111111-1111-1111-1111-111111111111
#FROZEN_NODE_OWNER_ID=<owner-uuid>
